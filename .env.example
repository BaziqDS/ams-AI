# LANGSMITH_API_KEY=""
# LANGSMITH_TRACING_V2="true"
# LANGSMITH_PROJECT="default"

TAVILY_API_KEY=""

# Agent model provider. Use "groq" to call Groq directly, or "openrouter".
AGENT_MODEL_PROVIDER="openrouter"

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_NAME="LangChain Agent Chat App"
# Optional OpenRouter reasoning controls for thinking-capable models.
# OPENROUTER_REASONING_ENABLED="true"
# OPENROUTER_REASONING_EFFORT="low" # low | medium | high
# OPENROUTER_REASONING_MAX_TOKENS="2048"
# OPENROUTER_REASONING_EXCLUDE="true"

GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Optional SQL connection.
# By default, the agent reads ../../ams-backend/db.sqlite3 from this workspace.
# Set SQLITE_DATABASE_PATH for another SQLite file, or DATABASE_URL for postgres/sqlite.
# SQLITE_DATABASE_PATH=""
# DATABASE_URL="postgresql://user:password@localhost:5432/database"
